@using Microsoft.JSInterop
@using MudBlazor.Services
@inherits LayoutComponentBase
@implements IBrowserViewportObserver
@inject IJSRuntime JS
@inject NavigationManager Navigation

<MudLayout>
    <MudAppBar Color="Color.Primary" Elevation="1">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleDrawer" />
        <MudText Typo="Typo.h6">Tesla Cam Viewer</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Elevation="1"
               Width="400px"
               Variant="@DrawerVariant.Responsive"
               Breakpoint="Breakpoint.Md">
        <MudDrawerContainer>
            <MudGrid Style="margin-top:10px">
                <!-- Statistics Section -->
                <MudItem xs="12">
                    <MudPaper Class="pa-3 drawer-section" Elevation="3">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6" Align="Align.Center">Statistics</MudText>
                            <MudGrid Spacing="1">
                                <MudItem xs="6">
                                    <MudPaper Class="pa-2" Style="background-color: var(--mud-palette-primary); color: white;">
                                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.h4">@_totalEvents</MudText>
                                            <MudText Typo="Typo.caption">Total Events</MudText>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudPaper Class="pa-2" Style="background-color: var(--mud-palette-secondary); color: white;">
                                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.h4">@_eventsThisMonth</MudText>
                                            <MudText Typo="Typo.caption">This Month</MudText>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudPaper Class="pa-2" Style="background-color: var(--mud-palette-tertiary); color: white;">
                                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.h4">@_sentryEvents</MudText>
                                            <MudText Typo="Typo.caption">Sentry</MudText>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                                <MudItem xs="6">
                                    <MudPaper Class="pa-2" Style="background-color: var(--mud-palette-info); color: white;">
                                        <MudStack Spacing="0" AlignItems="AlignItems.Center">
                                            <MudText Typo="Typo.h4">@_savedEvents</MudText>
                                            <MudText Typo="Typo.caption">Saved</MudText>
                                        </MudStack>
                                    </MudPaper>
                                </MudItem>
                            </MudGrid>

                            <MudButton OnClick="OnStatisticsClicked"
                                       Variant="Variant.Text"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       EndIcon="@Icons.Material.Filled.ArrowForward">
                                View Detailed Statistics
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <!-- Events Section -->
                <MudItem xs="12">
                    <MudPaper Class="pa-3 drawer-section" Elevation="3">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6" Align="Align.Center">Events</MudText>
                            <MudButton OnClick="OnEventsClicked"
                                       Variant="Variant.Text"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       EndIcon="@Icons.Material.Filled.ArrowForward">
                                View events
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>

                <!-- Statistics Section -->
                <MudItem xs="12">
                    <MudPaper Class="pa-3 drawer-section" Elevation="3">
                        <MudStack Spacing="2">
                            <MudText Typo="Typo.h6" Align="Align.Center">Calendar</MudText>
                            <MudButton OnClick="OnCalendarClicked"
                                       Variant="Variant.Text"
                                       Color="Color.Primary"
                                       FullWidth="true"
                                       EndIcon="@Icons.Material.Filled.ArrowForward">
                                View Calendar with clips
                            </MudButton>
                        </MudStack>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudDrawerContainer>
    </MudDrawer>

    <MudMainContent>
        @Body
    </MudMainContent>
</MudLayout>

@code {
    [Inject]
    private IBrowserViewportService BrowserViewportService { get; set; } = null!;
    private bool _drawerOpen = true;
    public ClipItem? SelectedEvent { get; set; }
    private Breakpoint _currentBreakpoint;

    Guid IBrowserViewportObserver.Id { get; } = Guid.NewGuid();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await BrowserViewportService.SubscribeAsync(this, fireImmediately: true);
        }
        await base.OnAfterRenderAsync(firstRender);
    }

    ResizeOptions IBrowserViewportObserver.ResizeOptions { get; } = new()
    {
        ReportRate = 250,
        NotifyOnBreakpointOnly = true
    };

    private void ToggleDrawer()
    {
        _drawerOpen = !_drawerOpen;
    }

    private async Task OnCalendarClicked()
    {
        if (_currentBreakpoint < Breakpoint.Md)
        {
            _drawerOpen = false;
        }

        Navigation.NavigateTo("/calendar");
        StateHasChanged();
    }

    private async Task OnStatisticsClicked()
    {
        if (_currentBreakpoint < Breakpoint.Md)
        {
            _drawerOpen = false;
        }

        Navigation.NavigateTo("/statistics");
        StateHasChanged();
    }

    private async Task OnEventsClicked()
    {
        if (_currentBreakpoint < Breakpoint.Md)
        {
            _drawerOpen = false;
        }

        Navigation.NavigateTo("/events");
        StateHasChanged();
    }

    Task IBrowserViewportObserver.NotifyBrowserViewportChangeAsync(BrowserViewportEventArgs browserViewportEventArgs)
    {
        _currentBreakpoint = browserViewportEventArgs.Breakpoint;
        return InvokeAsync(StateHasChanged);
    }
}
